# =============================================================================
# Content Curator - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Twitter/X API Credentials
# -----------------------------------------------------------------------------
# Get from: https://developer.x.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_bearer_token_here
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_CLIENT_ID=your_client_id_here
TWITTER_CLIENT_SECRET=your_client_secret_here

# -----------------------------------------------------------------------------
# Instagram API Credentials
# -----------------------------------------------------------------------------
# Get from: https://developers.facebook.com/apps
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
INSTAGRAM_APP_ID=your_app_id_here
INSTAGRAM_APP_SECRET=your_app_secret_here

# -----------------------------------------------------------------------------
# AI Provider (choose ONE)
# -----------------------------------------------------------------------------
# OpenRouter (recommended): https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key_here

# OR Groq (free tier): https://console.groq.com
# GROQ_API_KEY=your_groq_key_here

# -----------------------------------------------------------------------------
# AI Configuration
# -----------------------------------------------------------------------------
AI_PROVIDER=openrouter
AI_MODEL=meta-llama/llama-3.3-70b-instruct

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./curator.db

# -----------------------------------------------------------------------------
# Development Mode
# -----------------------------------------------------------------------------
# IMPORTANT: Set to 'true' during development to limit API calls
# Set to 'false' in production
DEV_MODE=true

# Maximum items to process in DEV_MODE (prevents costly mistakes)
MAX_DEV_ITEMS=10

# -----------------------------------------------------------------------------
# Cost Limits (USD)
# -----------------------------------------------------------------------------
# Hard limits - system will stop if exceeded
MAX_DAILY_COST_USD=0.50
MAX_MONTHLY_COST_USD=5.00

# Alert thresholds
ALERT_DAILY_COST_USD=0.30
ALERT_MONTHLY_COST_USD=3.00

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/curator.log

# -----------------------------------------------------------------------------
# Optional: Notifications
# -----------------------------------------------------------------------------
# Email notifications for cost alerts (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# ALERT_EMAIL=your_email@gmail.com

# Discord webhook for alerts (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
