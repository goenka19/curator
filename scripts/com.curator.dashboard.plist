<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.curator.dashboard</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/Users/ujjwalgoenka/Desktop/Coding/curator/backend/venv/bin/python</string>
        <string>-c</string>
        <string>import sys; sys.path.insert(0, '/Users/ujjwalgoenka/Desktop/Coding/curator'); from backend.cli import dashboard_check_command; dashboard_check_command()</string>
    </array>
    
    <key>WorkingDirectory</key>
    <string>/Users/ujjwalgoenka/Desktop/Coding/curator</string>
    
